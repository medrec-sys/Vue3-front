{
  "extends": ["@vue/tsconfig/tsconfig.dom.json", "./tsconfig.json"],
  "compilerOptions": {
    /* ================= 编译输出配置 ================= */
    "composite": true,                   // 启用项目组合编译
    "declaration": true,                 // 生成声明文件(.d.ts)
    "declarationDir": "types",           // 声明文件输出目录
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo", // 增量编译缓存
    "noEmit": false,                     // 允许输出文件
    "emitDeclarationOnly": false,        // 允许输出JS文件

    /* ================= 模块系统配置 ================= */
    "esModuleInterop": true,             // 兼容CommonJS/ES模块
    "allowSyntheticDefaultImports": true, // 允许无默认导出的默认导入
    "allowImportingTsExtensions": false,  // 禁止import时带.ts扩展名
    "types": ["vite/client"],            // 包含Vite环境类型

    /* ================= 严格类型检查 ================= */
    "strict": true,                      // 启用所有严格检查
    "exactOptionalPropertyTypes": true,  // 精确可选属性类型
    "noImplicitOverride": true,          // 要求显式override标记
    "noImplicitReturns": true,           // 函数必须显式返回
    "noUncheckedSideEffectImports": true,// 禁止未验证副作用导入

    /* ================= 代码质量检查 ================= */
    "noUnusedLocals": true,              // 报错未使用的局部变量
    "noUnusedParameters": true,          // 报错未使用的函数参数
    "noFallthroughCasesInSwitch": true,  // 禁止switch case穿透

    /* ================= 其他安全配置 ================= */
    "skipLibCheck": true,                // 跳过库文件类型检查
    "forceConsistentCasingInFileNames": true, // 强制文件名大小写一致
    "noPropertyAccessFromIndexSignature": true, // 禁止点语法访问索引签名
    "jsx": "preserve"                    // 保留JSX语法（Vue TSX项目）
  },

  /* ================= 文件范围配置 ================= */
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue"
  ],
  "exclude": [
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/__tests__/**"
  ]
}
